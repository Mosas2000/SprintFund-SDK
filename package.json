{
  "name": "sf-protocol",
  "version": "0.0.0",
  "description": "SF Protocol - Stacks blockchain governance SDK",
  "private": true,
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/core",
    "packages/react",
    "packages/indexer"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "test": "npm run test --workspaces",
    "test:coverage": "npm run test:coverage --workspaces",
    "build": "npm run build --workspaces",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "clean": "npm run clean --workspaces && rm -rf dist coverage"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "typescript": "^5.3.3"
  }
}
