{
  "name": "@sf-protocol/cli",
  "version": "0.1.0",
  "description": "Command-line interface for SF Protocol SDK development",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "sf-protocol": "./bin/sf-protocol.js",
    "sfp": "./bin/sf-protocol.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stacks",
    "blockchain",
    "governance",
    "cli",
    "developer-tools",
    "code-generation",
    "scaffolding"
  ],
  "author": "SF Protocol Team",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.0.0",
    "enquirer": "^2.4.1",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8",
    "dedent": "^1.5.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Mosas2000/SprintFund-SDK.git",
    "directory": "packages/cli"
  }
}
