{
  "name": "@sf-protocol/indexer",
  "version": "0.2.0",
  "description": "PostgreSQL blockchain indexer and analytics API for SF Protocol",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "node --loader tsx src/index.ts",
    "start": "node dist/index.js",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate:pg",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sf-protocol/core": "^0.1.0",
    "@tanstack/react-query": "^5.28.0",
    "apollo-server-express": "^3.13.0",
    "bull": "^4.11.0",
    "drizzle-orm": "^0.29.0",
    "express": "^4.18.0",
    "graphql": "^16.8.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "drizzle-kit": "^0.20.0",
    "eslint": "^8.56.0",
    "supertest": "^6.3.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.0"
  }
}
